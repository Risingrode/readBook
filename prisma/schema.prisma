generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Book {
  id           String   @id @default(cuid())
  title        String
  format       String   // "txt", "pdf", "epub"
  filePath     String   // path where the file is stored
  coverImage   String?  // optional cover
  extractedText String? // for small/medium books, or just metadata
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  progress     ReadingProgress?
  bookmarks    Bookmark[]
  annotations  Annotation[]
}

model ReadingProgress {
  id           String   @id @default(cuid())
  bookId       String   @unique
  book         Book     @relation(fields: [bookId], references: [id], onDelete: Cascade)
  progress     Float    @default(0) // 0 to 100 percentage
  lastRead     DateTime @default(now())
}

model UserStats {
  id           String   @id @default(cuid())
  totalReadMin Int      @default(0)
  lastReadDate DateTime @default(now())
}

model Bookmark {
  id        String   @id @default(cuid())
  bookId    String
  book      Book     @relation(fields: [bookId], references: [id], onDelete: Cascade)
  progress  Float    // 0-100 percentage position in the book
  label     String?  // optional user label/note
  mode      String   @default("paginate") // "paginate" or "scroll" — which mode the bookmark was created in
  slideIndex Int?    // slide index for paginate mode
  createdAt DateTime @default(now())
}

model Annotation {
  id        String   @id @default(cuid())
  bookId    String
  book      Book     @relation(fields: [bookId], references: [id], onDelete: Cascade)
  text      String   // The highlighted text
  prefix    String?  // ~20 chars before, for resilient matching
  suffix    String?  // ~20 chars after, for resilient matching
  note      String?  // null if just a highlight (no note)
  color     String   @default("yellow") // highlight color key
  progress  Float    // position for jump
  mode      String   @default("paginate")
  slideIndex Int?    // slide index for paginate mode
  createdAt DateTime @default(now())
}
